# PipelineGuard — Docker Compose Environment
# Copy this file to .env and fill in the values.
# Run: python scripts/generate_keys.py   to auto-generate JWT keys and create .env

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_dev

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── JWT Keys (RSA-2048 PEM — generated by scripts/generate_keys.py) ──────────
# Paste output from: python scripts/generate_keys.py
APP_JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
<your private key here>
-----END RSA PRIVATE KEY-----"

APP_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<your public key here>
-----END PUBLIC KEY-----"
